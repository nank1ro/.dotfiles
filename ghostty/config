# Font
font-family = JetBrains Mono
font-size = 15

# Theme
theme = Dracula+

# Window
macos-titlebar-style = tabs
window-padding-x = 4
window-padding-y = 4

# Misc
confirm-close-surface = false
mouse-scroll-multiplier = 0.2

# Keybindings: send special chars to NeoVim for CMD+ keys
# These match the <Char-0xNN> mappings in nvim/lua/config/keymaps.lua
keybind = super+s=text:\xAA
keybind = super+x=text:\xAB
keybind = super+b=text:\xAC
keybind = super+period=text:\xAD
keybind = super+o=text:\xAF
keybind = super+slash=text:\xB0
